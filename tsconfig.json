{
	"compilerOptions": {
		"target": "es2024",
		"lib": ["es2024"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"resolveJsonModule": true,
		"noEmit": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"./worker-configuration.d.ts",
			"node"
		]
	}
}
