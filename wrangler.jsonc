{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "twitch-gsheet-tracker",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-04",
	"queues": {
		"consumers": [
			{
				"queue": "twitch-sub-tracker"
			}
		],
		"producers": [
			{
				"binding": "QUEUE",
				"queue": "twitch-sub-tracker"
			}
		]
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"BROADCASTER_ID": "55899594"
	}
}
